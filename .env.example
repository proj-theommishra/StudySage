# Copy this file to .env and fill in your API key below.
# Never commit your real .env file — add .env to .gitignore.

# ============================================
# OPTION A — Google Gemini (recommended, genuinely free — no card needed)
# One key covers both LLM and embeddings.
# Get a free key at https://aistudio.google.com/apikey
# ============================================
LLM_PROVIDER="gemini"
LLM_MODEL="gemini/gemini-2.5-flash"
LLM_API_KEY="your_gemini_api_key_here"

EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="gemini/text-embedding-004"
EMBEDDING_API_KEY="your_gemini_api_key_here"
EMBEDDING_DIMENSIONS=768

# ============================================
# OPTION B — Groq (free, very fast — good backup if Gemini rate-limits you)
# Get a free key at https://console.groq.com
# Needs `pip install "cognee[fastembed]"` since Groq has no embedding models
# — Fastembed runs embeddings locally on your CPU, no key needed for that part.
# ============================================
# LLM_PROVIDER="custom"
# LLM_MODEL="groq/llama-3.3-70b-versatile"
# LLM_API_KEY="your_groq_api_key_here"
#
# EMBEDDING_PROVIDER="fastembed"
# EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
# EMBEDDING_DIMENSIONS=384

# ============================================
# OPTION C — OpenAI (simplest per the organizers' setup, but requires paid
# billing added to your account even at low usage — not free)
# ============================================
# LLM_PROVIDER="openai"
# LLM_MODEL="openai/gpt-5-mini"
# LLM_API_KEY="your_openai_api_key_here"
#
# EMBEDDING_PROVIDER="openai"
# EMBEDDING_MODEL="openai/text-embedding-3-large"
# EMBEDDING_API_KEY="your_openai_api_key_here"


